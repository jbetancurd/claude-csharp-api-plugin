  "howToUse": {
    "step1": "Read docs/decision-tree.md to determine your project path",
    "step2": "Copy relevant template from templates/[api-style]/[project-type]/",
    "step3": "Study the matching example from examples/[api-style]/[specific]/",
    "step4": "Implement following architecture and TDD patterns",
    "step5": "Verify against checklists/architecture-audit.md"
  },
  "supportedScenarios": [

  "architecture": {
    "type": "Onion Architecture",
    "layers": [
      "Domain (Core business logic, zero dependencies)",
      "Application (Use cases, services, DTOs)",
      "Infrastructure (Persistence, external services)",
      "Presentation (API, Controllers, HTTP)"
    ],
    "principles": [
      "SOLID (Single Responsibility, Open/Closed, Liskov, Interface Segregation, Dependency Inversion)",
      "DRY (Don't Repeat Yourself)",
      "TDD (Test-Driven Development)",
      "Clean Code"
    ]
  },
  "orms": {
    "dapper": {
      "description": "Lightweight, high-control data access",
      "template": "templates/shared/repositories/dapper-repository.template.cs",
      "best_for": ["Performance critical systems", "Legacy databases", "Fine-grained SQL control"]
    },
    "entityFramework": {
      "description": "Feature-rich ORM with Code-First approach",
      "template": "templates/shared/repositories/ef-repository.template.cs",
      "best_for": ["Domain-driven design", "Complex relationships", "Rapid development"]
    }
  },
  "apiStyles": {
    "rest": {
      "description": "Action-oriented API design",
      "guide": "docs/api-styles/rest-guide.md",
      "example": "examples/rest-api/todo-microservice/"
    },
    "restful": {
      "description": "Resource-oriented, HTTP-semantic API design",
      "guide": "docs/api-styles/restful-guide.md",
      "example": "examples/restful-api/inventory-full-api/"
    },
    "graphql": {
      "description": "Query language for flexible API design",
      "guide": "docs/api-styles/graphql-guide.md",
      "example": "examples/graphql-api/social-full-api/"
    }
  },
  "projectTypes": {
    "microservice": {
      "description": "Single responsibility, independent deployment",
      "characteristics": ["Small-to-medium size", "Own database", "Focused business capability"],
      "examplePath": "examples/{style}/[service]-microservice/"
    },
    "fullApi": {
      "description": "Complete business application API",
      "characteristics": ["Large scope", "Multiple domains", "All in one deployment"],
      "examplePath": "examples/{style}/[business]-full-api/"
    },
    "standalone": {
      "description": "Single function, often background work",
      "characteristics": ["Small scope", "Often event/timer-driven", "Specific responsibility"],
      "examplePath": "examples/{style}/[service]-service/"
    }
  },
  "technologies": {
    "required": [
      ".NET 6.0 or higher",
      "C# 10 or higher"
    ],
    "optional": [
      "Entity Framework Core",
      "Dapper",
      "Polly",
      "xUnit",
      "Moq",
      "FluentAssertions",
      "SignalR (WebSockets)",
      "Protocol Buffers",
